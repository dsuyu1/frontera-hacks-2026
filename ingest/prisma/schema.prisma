generator client {
  provider      = "prisma-client-js"
  /// AWS Lambda (Amazon Linux 2023) + local dev
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Region / county / city hierarchy for feed scoping (PRD §8.1).
model Locality {
  id        String     @id @default(cuid())
  name      String
  region    String?
  county    String?
  city      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  sources   Source[]
  feedItems FeedItem[]
}

/// Editable category set (PRD §7).
model Category {
  id                 String              @id @default(cuid())
  slug               String              @unique
  name               String
  createdAt          DateTime            @default(now())
  feedItemCategories FeedItemCategory[]
}

/// Configured ingest origin + cursor for incremental runs (PRD §8.2).
model Source {
  id                  String    @id @default(cuid())
  name                String
  localityId          String
  locality            Locality  @relation(fields: [localityId], references: [id], onDelete: Cascade)
  /// youtube_channel | rss | html_list
  type                String
  /// Opaque JSON: channelId, feedUrl, selectors, etc.
  config              Json
  enabled             Boolean   @default(true)
  respectRobots       Boolean   @default(true)
  crawlDelayMs        Int?
  userAgent           String?
  lastSuccessAt       DateTime?
  /// Cursor: newest item publication time we have fully processed (incremental window).
  lastSeenPublishedAt DateTime?
  lastSeenItemKey     String?
  lastRunStatus       String?
  lastRunError        String?
  lastRunAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  sourceItems         SourceItem[]
  feedItems           FeedItem[]

  @@index([enabled, type])
}

/// Raw discovered row before feed merge / dedupe (PRD §8.2).
model SourceItem {
  id               String   @id @default(cuid())
  sourceId       String
  source         Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  /// External stable id e.g. YouTube video id.
  externalId     String
  title          String
  url            String
  publishedAt    DateTime
  dedupeHash     String
  rawSnapshotKey String?
  createdAt      DateTime @default(now())

  @@unique([sourceId, externalId])
  @@index([dedupeHash])
  @@index([publishedAt])
}

/// User-facing feed entry (PRD §9).
model FeedItem {
  id           String             @id @default(cuid())
  /// text | video
  type         String
  localityId   String
  locality     Locality           @relation(fields: [localityId], references: [id], onDelete: Cascade)
  jurisdiction String
  publishedAt  DateTime
  title        String
  summary      String?
  sourceUrl    String
  dedupeHash   String             @unique
  sourceId     String?
  source       Source?            @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  categories   FeedItemCategory[]

  @@index([localityId, publishedAt])
  @@index([sourceId])
}

model FeedItemCategory {
  feedItemId String
  categoryId String
  feedItem   FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([feedItemId, categoryId])
}
